<Window x:Class="ClinicaVeterinariaWPF.AppointmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:local="clr-namespace:ClinicaVeterinariaWPF"
        mc:Ignorable="d"
        Title="AppointmentWindow" Height="700" Width="850">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Procurar por:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox x:Name="ComboBoxSearch" Width="120" Margin="0,0,10,0">
                <ComboBoxItem Content="Animal"/>
                <ComboBoxItem Content="Doutor"/>
                <ComboBoxItem Content="Data"/>
            </ComboBox>
            <TextBox x:Name="TextBoxName" Width="150" Margin="0,0,10,0"/>
            <TextBlock Text="ou escolha o dia:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <DatePicker x:Name="DatePickerSearch" Width="130" Margin="0,0,10,0"/>
            <Button x:Name="btnSearch" Content="Procurar" Width="80" Click="btnSearch_Click"/>
        </StackPanel>

        <DataGrid x:Name="DataGridSearch" Grid.Row="1" Margin="0,0,0,10" AutoGenerateColumns="False" IsReadOnly="true" SelectionChanged="DataGridSearch_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Data" Binding="{Binding Date}" Width="*"/>
                <DataGridTextColumn Header="Animal" Binding="{Binding AnimalName}" Width="*"/>
                <DataGridTextColumn Header="Doutor" Binding="{Binding DoctorName}" Width="*"/>
                <DataGridTextColumn Header="Sala" Binding="{Binding RoomId}" Width="60"/>
                <DataGridTextColumn Header="Cancelada" Binding="{Binding Cancelada}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
            <Button x:Name="btnEdit" Content="Editar" Width="80" Margin="0,0,10,0" Click="btnEdit_Click"/>
            <Button x:Name="btnDelete" Content="Eliminar" Width="80" Click="btnDelete_Click"/>
        </StackPanel>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <TextBlock Text="Animal"/>
                <ComboBox x:Name="ComboBoxAnimal" DisplayMemberPath="Name" Margin="0,0,0,5"/>
                <TextBlock Text="Doutor"/>
                <ComboBox x:Name="ComboBoxDoctor" DisplayMemberPath="Name" Margin="0,0,0,5"/>
                <TextBlock Text="Sala"/>
                <ComboBox x:Name="ComboBoxRoom" DisplayMemberPath="Id" Margin="0,0,0,5"/>
                <TextBlock Text="Motivo"/>
                <TextBox x:Name="TextBoxMotive" Margin="0,0,0,5"/>
                <TextBlock Text="Tratamento"/>
                <TextBox x:Name="TextBoxTreatment" Margin="0,0,0,5"/>
                <CheckBox x:Name="CheckBoxCanceled" Content="Cancelada" Margin="0,0,0,5"/>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Data"/>
                <DatePicker x:Name="DatePickerDate" Margin="0,0,0,10"/>
                <TextBlock Text="Hora de Início"/>
                <xctk:TimePicker x:Name="TimePickerStart" Format="ShortTime" Margin="0,0,0,10"/>
                <TextBlock Text="Hora de fim"/>
                <xctk:TimePicker x:Name="TimePickerEnd" Format="ShortTime"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnNew" Content="Novo" Width="80" Margin="0,0,10,0" Click="btnNew_Click"/>
            <Button x:Name="btnSave" Content="Guardar" Width="80" Margin="0,0,10,0"  Click="btnSave_Click"/>
            <Button x:Name="btnClose" Content="Fechar" Width="80" Click="btnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
