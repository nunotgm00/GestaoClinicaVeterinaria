<Window x:Class="ClinicaVeterinariaWPF.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClinicaVeterinariaWPF"
        mc:Ignorable="d"
        Title="Gestão de Clientes" Height="500" Width="900">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Procurar por:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="ComboBoxSearch" Width="100" Margin="0,0,10,0">
                <ComboBoxItem Content="Nome"/>
                <ComboBoxItem Content="NIF"/>
                <ComboBoxItem Content="Telefone"/>
            </ComboBox>
            <TextBox x:Name="TextBoxSearch" Width="200" Margin="0,0,10,0"/>
            <Button x:Name="btnSearch" Content="Procurar" Width="80" Click="btnSearch_Click"/>
        </StackPanel>

        <DataGrid x:Name="DataGridSearch" Grid.Row="1" Margin="0,0,0,10" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="DataGridSearch_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="2*"/>
                <DataGridTextColumn Header="NIF" Binding="{Binding Nif}" Width="*"/>
                <DataGridTextColumn Header="Telefone" Binding="{Binding PhoneNumber}" Width="*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
            <Button x:Name="btnEdit" Content="Editar" Width="80" Margin="0,0,10,0" Click="btnEdit_Click"/>
            <Button x:Name="btnDelete" Content="Eliminar" Width="80" Margin="0,0,10,0" Click="btnDelete_Click_1"/>
        </StackPanel>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <TextBlock Text="Nome"/>
                <TextBox x:Name="TextBoxName" Margin="0,0,0,5"/>
                <TextBlock Text="Morada"/>
                <TextBox x:Name="TextBoxAddress" Margin="0,0,0,5"/>
                <TextBlock Text="NIF"/>
                <TextBox x:Name="TextBoxNif" Margin="0,0,0,5"/>
                <TextBlock Text="Telefone"/>
                <TextBox x:Name="TextBoxPhoneNumber" Margin="0,0,0,5"/>
                <TextBlock Text="Email"/>
                <TextBox x:Name="TextBoxEmail" Margin="0,0,0,5"/>
            </StackPanel>

            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Sem dono" FontWeight="Bold"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Associado ao cliente" FontWeight="Bold"/>

                <ListBox x:Name="ListBoxAvailableAnimals" Grid.Row="1" Grid.Column="0" DisplayMemberPath="Name"/>

                <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="5,0,5,0">
                    <Button x:Name="btnAddAnimal" Content="&gt;&gt;" Width="35" Margin="0,0,0,5" Click="btnAddAnimal_Click"/>
                    <Button x:Name="btnRemoveAnimal" Content="&lt;&lt;" Width="35" Click="btnRemoveAnimal_Click"/>
                </StackPanel>

                <ListBox x:Name="ListBoxClientAnimals" Grid.Row="1" Grid.Column="2" DisplayMemberPath="Name"/>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnNew" Content="Novo" Width="80" Margin="0,0,10,0" Click="btnNew_Click_1"/>
            <Button x:Name="btnSave" Content="Guardar" Width="80" Margin="0,0,10,0" Click="btnSave_Click_1"/>
            <Button x:Name="btnClose" Content="Fechar" Width="80" Click="btnClose_Click_1"/>
        </StackPanel>

    </Grid>
</Window>
