<Window x:Class="ClinicaVeterinariaWPF.AnimalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClinicaVeterinariaWPF"
        mc:Ignorable="d"
        Title="AnimalWindow" Height="650" Width="850">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Procurar por:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="ComboBoxSearch" Width="100" Margin="0,0,10,0">
                <ComboBoxItem Content="Nome"/>
                <ComboBoxItem Content="Espécie"/>
                <ComboBoxItem Content="Dono"/>
            </ComboBox>
            <TextBox x:Name="TextBoxSearch" Width="200" Margin="0,0,10,0"/>
            <Button x:Name="btnSearch" Content="Procurar" Width="80" Click="btnSearch_Click"/>
        </StackPanel>

        <DataGrid x:Name="DataGridResults" Grid.Row="1" Margin="0,0,0,10" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="DataGridResults_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="2*"/>
                <DataGridTextColumn Header="Espécie" Binding="{Binding Species}" Width="*"/>
                <DataGridTextColumn Header="Raça" Binding="{Binding Breed}" Width="*"/>
                <DataGridTextColumn Header="Idade" Binding="{Binding Age}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
            <Button x:Name="btnEdit" Content="Editar" Width="80" Margin="0,0,10,0" Click="btnEdit_Click"/>
            <Button x:Name="btnDelete" Content="Eliminar" Width="80" Click="btnDelete_Click"/>
        </StackPanel>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="470"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <TextBlock Text="Nome"/>
                <TextBox x:Name="TextBlockName" Margin="0,0,0,5"/>
                <TextBlock Text="Espécie"/>
                <TextBox x:Name="TextBlockSpecies" Margin="0,0,0,5"/>
                <TextBlock Text="Raça"/>
                <TextBox x:Name="TextBlockBreed" Margin="0,0,0,5"/>
                <TextBlock Text="Idade"/>
                <TextBox x:Name="TextBlockAge" Margin="0,0,0,5"/>
                <TextBlock Text="Peso (Kg)"/>
                <TextBox x:Name="TextBlockWeight" Margin="0,0,0,5"/>
                <TextBlock Text="Cor"/>
                <TextBox x:Name="TextBlockColor" Margin="0,0,0,5"/>
                <TextBlock Text="Sexo"/>
                <ComboBox x:Name="ComboBoxSex" Margin="0,0,0,5">
                    <ComboBoxItem Content="Masculino"/>
                    <ComboBoxItem Content="Feminino"/>
                    <ComboBoxItem Content="Outro"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Consultas" FontWeight="Bold" Margin="0,0,0,5"/>
                <DataGrid x:Name="DataGridAppointments" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Data" Binding="{Binding Date}" Width="*"/>
                        <DataGridTextColumn Header="Motivo" Binding="{Binding Motive}" Width="2*"/>
                        <DataGridTextColumn Header="Sala" Binding="{Binding Room}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnNew" Content="Novo" Width="80" Margin="0,0,10,0" Click="btnNew_Click"/>
            <Button x:Name="btnSave" Content="Guardar" Width="80" Margin="0,0,10,0"  Click="btnSave_Click"/>
            <Button x:Name="btnClose" Content="Fechar" Width="80" Click="btnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
